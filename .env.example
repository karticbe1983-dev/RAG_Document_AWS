# Copy this file to .env and fill in real values (never commit .env)

AWS_REGION=us-east-1
AWS_PROFILE=default

# S3 buckets (output from Terraform)
S3_BUCKET_NAME=rag-document-aws-docs-<suffix>
S3_ARTIFACTS_BUCKET=rag-document-aws-artifacts-<suffix>

# OpenSearch Serverless
OPENSEARCH_ENDPOINT=<collection-id>.us-east-1.aoss.amazonaws.com
OPENSEARCH_INDEX=rag-index

# Bedrock
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0
BEDROCK_LLM_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0
EMBED_DIMENSIONS=1024

# Bedrock Agent / Knowledge Base (output from Terraform)
KNOWLEDGE_BASE_ID=<kb-id>
DATA_SOURCE_ID=<ds-id>
AGENT_ID=<agent-id>
AGENT_ALIAS_ID=<alias-id>

# Application defaults
DEFAULT_CHUNK_SIZE=1000
DEFAULT_CHUNK_OVERLAP=200
DEFAULT_CHUNKING_STRATEGY=recursive
TOP_K_RESULTS=5
LOG_LEVEL=INFO
